############################
# Supabase — secrets
# YOU MUST CHANGE ALL DEFAULTS BEFORE FIRST RUN
############################

POSTGRES_PASSWORD=your-super-secret-postgres-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# JWT signing secret (min 32 chars)
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# API keys — generate with:
#   npx supabase@latest gen keys --project-ref local
# or: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=<your-anon-jwt>
SERVICE_ROLE_KEY=<your-service-role-jwt>

# Encryption key for postgres-meta (min 32 chars)
PG_META_CRYPTO_KEY=your-32-character-encryption-key-here

############################
# Supabase — URLs
############################
SUPABASE_PUBLIC_URL=http://localhost:8000

############################
# Supabase Studio
############################
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=supabase
STUDIO_DEFAULT_ORGANIZATION=WCS
STUDIO_DEFAULT_PROJECT=Warehouse Control System
STUDIO_PORT=54323
OPENAI_API_KEY=

############################
# Kong
############################
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############################
# Storage
############################
STORAGE_FILE_SIZE_LIMIT=52428800
STORAGE_TENANT_ID=stub
REGION=stub
GLOBAL_S3_BUCKET=stub
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

############################
# WCS application
############################
GRAPH_ID=1

# GraphQL IDE: graphiql | apollo-sandbox | graphql-playground
GRAPHQL_IDE=graphiql

# Robot fleet configuration (JSON)
# Format: '{"RobotName": {"host": "IP", "port": PORT, "cell_heights": [h1, h2, h3]}}''
# ROBOTS_CONFIG='{"FACOBOT": {"host": "10.61.6.65", "port": 9090, "cell_heights": [0.653, 1.073, 1.493, 1.913]}}'
ROBOTS_CONFIG='{"SIMBOT": {"host": "robot_simulator", "port": 9090, "cell_heights": [0.653, 1.073, 1.493, 1.913]}}'
